# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Telegram (optional) ----------------------------------------------------
# Create a bot with @BotFather to get the token; get your chat id from @userinfobot.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- Generic webhook (optional) ---------------------------------------------
# Slack incoming webhook, Discord webhook, or any endpoint accepting {"text": "..."}.
FLEET_WEBHOOK_URL=

# --- vps-health example agent thresholds (optional) -------------------------
# DISK_PCT_MAX=85
# MEM_AVAIL_MIN_PCT=10
# LOG_SIZE_MAX=+500M
# LOG_SCAN_DIRS=/var/log

# --- backup-verify example agent (optional) ---------------------------------
# BACKUP_DIR=/home/me/backups
# BACKUP_GLOB=*.sql.gz
# BACKUP_MAX_AGE_H=26
# BACKUP_MIN_BYTES=102400
